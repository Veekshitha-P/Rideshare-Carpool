# ================================================================
#  RideShare — Carpooling Coordinator
#  .gitignore
# ================================================================

# ── Python / FastAPI ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
*.xml

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# ── Environment & Secrets ────────────────────────────────────────
# NEVER commit your database password
.env
.env.local
.env.production
config.py          # contains DB password — keep this out of git!

# ── Database ─────────────────────────────────────────────────────
*.sql.bak
*.db
*.sqlite
*.sqlite3

# MySQL dumps / exports
*.dump
*_backup.sql

# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Build output (if you ever add a bundler)
/dist
/build
/.next
/.nuxt

# ── OS Files ─────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── Editor / IDE ─────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.emacs.desktop

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# ── Misc ─────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
.history/
